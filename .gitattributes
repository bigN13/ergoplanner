# Auto detect text files and perform LF normalization
* text=auto

# Force LF for all text files (cross-platform compatibility)
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.dockerfile text eol=lf
Dockerfile text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE text eol=lf
README text eol=lf

# Windows specific files should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.jar binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.otf binary

# Documents
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.odt binary
*.ods binary
*.odp binary

# Audio/Video
*.mp3 binary
*.mp4 binary
*.wav binary
*.flac binary
*.ogg binary
*.webm binary

# Large files that should use Git LFS
*.psd filter=lfs diff=lfs merge=lfs -text
*.ai filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text
*.fig filter=lfs diff=lfs merge=lfs -text
*.xd filter=lfs diff=lfs merge=lfs -text

# ML Model files (use Git LFS)
*.h5 filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.model filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.caffemodel filter=lfs diff=lfs merge=lfs -text
*.pb filter=lfs diff=lfs merge=lfs -text

# Database dumps (use Git LFS for large dumps)
*.dump filter=lfs diff=lfs merge=lfs -text
*.sql.gz filter=lfs diff=lfs merge=lfs -text

# Diff settings for specific files
*.cs diff=csharp
*.py diff=python
*.html diff=html
*.css diff=css
*.md diff=markdown
*.php diff=php
*.rb diff=ruby

# Linguist language overrides
*.tsx linguist-language=TypeScript
*.jsx linguist-language=JavaScript
docs/* linguist-documentation
*.md linguist-detectable=true
*.sql linguist-detectable=true

# Exclude from language statistics
frontend/public/vendor/* linguist-vendored
frontend/node_modules/* linguist-vendored
backend/packages/* linguist-vendored
*.min.js linguist-vendored
*.min.css linguist-vendored

# Files to exclude from exports (GitHub releases)
.github export-ignore
.gitignore export-ignore
.gitattributes export-ignore
.editorconfig export-ignore
tests/ export-ignore
docs/ export-ignore
*.test.* export-ignore
*.spec.* export-ignore