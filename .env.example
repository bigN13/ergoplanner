# ================================
# ERGOPLANNER AI SUITE
# Environment Configuration Template
# ================================
# Copy this file to .env.local and update with your values
# NEVER commit .env.local to version control

# ================================
# APPLICATION SETTINGS
# ================================
NODE_ENV=development
APP_NAME="Ergoplanner AI Suite"
APP_VERSION=0.1.0
APP_PORT=3000
API_PORT=5000
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ================================
# DATABASE CONFIGURATION
# ================================
# PostgreSQL Connection
DATABASE_URL=postgresql://ergoplanner:your_password_here@localhost:5432/ergoplanner_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ergoplanner_dev
DATABASE_USER=ergoplanner
DATABASE_PASSWORD=your_password_here
DATABASE_SSL_MODE=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ================================
# REDIS CONFIGURATION
# ================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ================================
# AUTHENTICATION & SECURITY
# ================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_MAX_AGE=86400000

# OAuth Providers (Optional)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ================================
# EXTERNAL SERVICES
# ================================
# Microsoft Graph API (Teams/SharePoint Integration)
GRAPH_API_CLIENT_ID=
GRAPH_API_CLIENT_SECRET=
GRAPH_API_TENANT_ID=
GRAPH_API_SCOPE=https://graph.microsoft.com/.default

# Email Service (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ergoplanner.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Cloud Storage (Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=ergoplanner-files

# ================================
# AI/ML SERVICES
# ================================
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=
OPENAI_API_KEY=
AI_MODEL_PATH=/models
AI_PROCESSING_TIMEOUT=30000

# ================================
# MESSAGE QUEUE
# ================================
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ================================
# MONITORING & LOGGING
# ================================
# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=20m

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# ================================
# FEATURE FLAGS
# ================================
ENABLE_AI_FEATURES=true
ENABLE_REAL_TIME_COLLABORATION=true
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_DEBUG_MODE=true
ENABLE_SWAGGER=true
ENABLE_GRAPHQL=false

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# ================================
# CORS CONFIGURATION
# ================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ================================
# FILE UPLOAD
# ================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/svg+xml,application/pdf
UPLOAD_DIR=./uploads
TEMP_DIR=./temp

# ================================
# PERFORMANCE
# ================================
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
CACHE_TTL=3600
ENABLE_CLUSTER_MODE=false
WORKER_THREADS=4

# ================================
# DEVELOPMENT TOOLS
# ================================
# Hot Reload
NEXT_TELEMETRY_DISABLED=1
WATCHPACK_POLLING=true

# Debug
DEBUG=ergoplanner:*
DEBUG_SQL=false
DEBUG_REDIS=false
DEBUG_HTTP=false

# ================================
# DEPLOYMENT
# ================================
# Docker
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# Kubernetes
K8S_NAMESPACE=ergoplanner-dev
K8S_CONFIG_PATH=~/.kube/config

# ================================
# THIRD-PARTY INTEGRATIONS
# ================================
# SAP Integration
SAP_BASE_URL=
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=

# Oracle EBS
ORACLE_BASE_URL=
ORACLE_USERNAME=
ORACLE_PASSWORD=

# AutoCAD Web Services
AUTOCAD_API_KEY=
AUTOCAD_API_SECRET=

# ================================
# TESTING
# ================================
TEST_DATABASE_URL=postgresql://ergoplanner:test_password@localhost:5432/ergoplanner_test
TEST_REDIS_URL=redis://localhost:6379/1
E2E_BASE_URL=http://localhost:3000
PLAYWRIGHT_BROWSERS_PATH=./browsers

# ================================
# NOTES
# ================================
# - Replace all placeholder values with actual values
# - Use strong, unique passwords and secrets
# - Never commit actual values to version control
# - Keep production secrets in secure vault (Azure Key Vault, etc.)
# - Rotate secrets regularly
# - Use different values for each environment (dev, staging, prod)